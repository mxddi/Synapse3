        "EXPO_PUBLIC_GOOGLE_CLIENT_ID": "REPLACE_ME"
      }
    },
    "production": {
      "distribution": "store",
      "env": {
        "EXPO_PUBLIC_GOOGLE_CLIENT_ID": "REPLACE_ME"
      }
    }
  },
  "submit": {
    "production": {}
  }
}

